# Set to 'true' to use mock data instead of the real API
VITE_USE_MOCK=

# Override API base URL (default: /api/v1)
VITE_API_BASE_URL=

# Full URL for the clearskies-realtime SSE endpoint.
# When set, the dashboard opens an EventSource connection here for live loop
# packet updates.  Leave empty to disable SSE (REST-only mode).
# Example production value: http://192.168.2.113:8765/sse
# Example via Vite dev proxy (recommended for local dev): /sse
# Note: in local dev the Vite proxy forwards /sse to localhost:8766 (see
# vite.config.ts).  The realtime service and the API service must run on
# separate ports; realtime defaults to 8765 but you should override it to
# 8766 locally to avoid a collision with the API service.
VITE_SSE_URL=
